# Copy to .env for docker compose production usage.
DB_NAME=period_tracker
DB_USER=tracker
DB_PASSWORD=replace_with_long_random_password
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
API_KEY=replace_with_long_random_api_key
JWT_SECRET=replace_with_long_random_jwt_secret
SSH_USER=luna
# One-line OpenSSH public key, for example:
# ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... your_email@example
SSH_PUBLIC_KEY=replace_with_your_public_ssh_key
HA_WEBHOOK_URL=
HA_TOKEN=
